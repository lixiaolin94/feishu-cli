{
  "name": "feishu-cli",
  "version": "0.1.0",
  "description": "CLI for Feishu/Lark Open Platform APIs",
  "main": "dist/index.js",
  "bin": {
    "feishu-cli": "bin/feishu-cli.js"
  },
  "files": [
    "bin",
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist",
    "start": "node bin/feishu-cli.js",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run typecheck && npm run build"
  },
  "keywords": [
    "feishu",
    "lark",
    "cli"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lixiaolin94/feishu-cli.git"
  },
  "homepage": "https://github.com/lixiaolin94/feishu-cli#readme",
  "bugs": {
    "url": "https://github.com/lixiaolin94/feishu-cli/issues"
  },
  "type": "commonjs",
  "dependencies": {
    "@larksuiteoapi/lark-mcp": "^0.5.1",
    "@larksuiteoapi/node-sdk": "^1.59.0",
    "cli-table3": "^0.6.5",
    "commander": "^14.0.1",
    "dotenv": "^17.3.1",
    "yaml": "^2.8.1",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "@types/node": "^24.5.2",
    "tsup": "^8.5.0",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  }
}
